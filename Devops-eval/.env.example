# Copy to .env and fill in secrets (never commit .env)
#   cp .env.example .env

# ── Vercel deploy (./deploy.sh) ──────────────────────────────────
# Create token: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_NAME=devopsinfra-dash
# Set to 1 only on corporate VPN/proxy SSL errors
VERCEL_INSECURE_TLS=0
# Optional: path to company CA bundle (overrides auto macOS bundle)
# NODE_EXTRA_CA_CERTS=/path/to/company-ca.pem

# ── Local UI ports ───────────────────────────────────────────────
PORT=5173
D2_API_PORT=8000
D3_API_PORT=8002
D6_API_PORT=8001

# ── Grafana (local ./run-all-ui.sh) ──────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Postgres / D2 compose (local dev defaults) ─────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=devops_eval
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devops_eval
POLL_INTERVAL=2
